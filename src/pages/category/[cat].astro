---
import Layout from '../../layouts/Layout.astro';

const categories = [
  { id: 'us', label: 'U.S. News', labelBadge: 'U.S. News', color: '#c8102e' },
  { id: 'world', label: 'World News', labelBadge: 'World', color: '#1a5c8a' },
  { id: 'politics', label: 'Politics', labelBadge: 'Politics', color: '#3a2060' },
  { id: 'business', label: 'Business & Economy', labelBadge: 'Business', color: '#1a5c30' },
  { id: 'health', label: 'Health', labelBadge: 'Health', color: '#8a2020' },
  { id: 'entertainment', label: 'Entertainment', labelBadge: 'Entertainment', color: '#8a6020' },
  { id: 'travel', label: 'Travel', labelBadge: 'Travel', color: '#1a4a6a' },
  { id: 'sports', label: 'Sports', labelBadge: 'Sports', color: '#1a3a5c' },
  { id: 'science', label: 'Science', labelBadge: 'Science', color: '#2a1e5e' },
  { id: 'climate', label: 'Climate & Environment', labelBadge: 'Climate', color: '#1a5c30' },
  { id: 'tech', label: 'Technology', labelBadge: 'Tech', color: '#8a4020' },
];

export function getStaticPaths() {
  return [
    { params: { cat: 'us' } },
    { params: { cat: 'world' } },
    { params: { cat: 'politics' } },
    { params: { cat: 'business' } },
    { params: { cat: 'health' } },
    { params: { cat: 'entertainment' } },
    { params: { cat: 'travel' } },
    { params: { cat: 'sports' } },
    { params: { cat: 'science' } },
    { params: { cat: 'climate' } },
    { params: { cat: 'tech' } },
  ];
}

const { cat } = Astro.params;
const category = categories.find(c => c.id === cat)!;

const articleFiles = import.meta.glob('../../data/trunkpress/*.json', { eager: true });

interface Article {
  slug: string;
  title: string;
  description: string;
  category: string;
  published: string;
  tags?: string[];
  image?: string;
}

const articles: Article[] = Object.entries(articleFiles)
  .filter(([path]) => !path.includes('_schema') && !path.includes('_TEMPLATE'))
  .map(([_, mod]: [string, any]) => mod.default)
  .filter((a: any) => a?.slug && a.category === cat)
  .sort((a: Article, b: Article) => (b.published || '').localeCompare(a.published || ''));

function articleImage(article: Article): string {
  if (article.image) return article.image;
  return `/images/categories/${article.category || 'world'}.jpg`;
}

function timeAgo(dateStr: string): string {
  const d = new Date(dateStr + 'T12:00:00');
  const now = new Date();
  const diffH = Math.floor((now.getTime() - d.getTime()) / 3600000);
  if (diffH < 1) return 'Just now';
  if (diffH < 24) return `${diffH}h ago`;
  const diffD = Math.floor(diffH / 24);
  if (diffD === 1) return 'Yesterday';
  return `${diffD}d ago`;
}

function truncate(text: string, max: number): string {
  if (!text || text.length <= max) return text || '';
  return text.slice(0, max).replace(/\s+\S*$/, '') + '…';
}

const lead = articles[0];
const rest = articles.slice(1);
---

<Layout
  title={`${category.label} — Trunk Press`}
  description={`Latest ${category.label.toLowerCase()} coverage from Trunk Press.`}
  canonical={`https://trunkpress.photonbuilder.com/category/${cat}`}
>
  <style>
    .cat-header {
      max-width: 1200px;
      margin: 0 auto;
      padding: 48px 24px 24px;
      border-bottom: 3px solid #1a1a1a;
    }
    .cat-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      color: #1a1a1a;
      margin: 0;
    }
    .cat-count {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 0.88rem;
      color: #777;
      margin-top: 6px;
    }
    .cat-body {
      max-width: 1200px;
      margin: 0 auto;
      padding: 32px 24px 64px;
    }

    /* Lead story */
    .lead {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 32px;
      align-items: start;
      padding-bottom: 40px;
      margin-bottom: 40px;
      border-bottom: 1px solid #e0e0e0;
    }
    .lead-img {
      width: 100%;
      height: auto;
      aspect-ratio: 16/9;
      object-fit: cover;
      border-radius: 4px;
      display: block;
    }
    .lead-text h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.75rem;
      line-height: 1.2;
      margin: 0 0 12px;
    }
    .lead-text h2 a {
      color: #1a1a1a;
      text-decoration: none;
    }
    .lead-text h2 a:hover {
      text-decoration: underline;
    }
    .lead-deck {
      font-size: 1rem;
      line-height: 1.6;
      color: #444;
      margin: 0 0 12px;
    }
    .lead-meta {
      font-size: 0.82rem;
      color: #888;
    }

    /* Article grid */
    .articles-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }
    .card {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .card:hover h3 {
      text-decoration: underline;
    }
    .card-img {
      width: 100%;
      height: auto;
      aspect-ratio: 16/10;
      object-fit: cover;
      border-radius: 4px;
      display: block;
      margin-bottom: 12px;
    }
    .card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      line-height: 1.3;
      margin: 0 0 8px;
      color: #1a1a1a;
    }
    .card p {
      font-size: 0.88rem;
      line-height: 1.5;
      color: #555;
      margin: 0 0 8px;
    }
    .card .meta {
      font-size: 0.78rem;
      color: #999;
    }

    /* Back link */
    .back {
      display: inline-block;
      font-size: 0.85rem;
      color: #888;
      text-decoration: none;
      margin-bottom: 20px;
    }
    .back:hover { color: #1a1a1a; }

    @media (max-width: 768px) {
      .lead { grid-template-columns: 1fr; }
      .articles-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 1024px) and (min-width: 769px) {
      .articles-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

  <div class="cat-header">
    <h1 class="cat-title">{category.label}</h1>
    <div class="cat-count">{articles.length} article{articles.length !== 1 ? 's' : ''}</div>
  </div>

  <div class="cat-body">
    <a href="/" class="back">← Back to front page</a>

    {lead && (
      <div class="lead">
        <div class="lead-text">
          <h2><a href={`/${lead.slug}`}>{lead.title}</a></h2>
          <p class="lead-deck">{truncate(lead.description, 250)}</p>
          <div class="lead-meta">Trunk Press · {timeAgo(lead.published)}</div>
        </div>
      </div>
    )}

    {rest.length > 0 && (
      <div class="articles-grid">
        {rest.map(a => (
          <a href={`/${a.slug}`} class="card">
            <h3>{truncate(a.title, 80)}</h3>
            <p>{truncate(a.description, 130)}</p>
            <div class="meta">{timeAgo(a.published)}</div>
          </a>
        ))}
      </div>
    )}

    {articles.length === 0 && (
      <p style="color:#888; padding: 40px 0;">No articles in this category yet.</p>
    )}
  </div>
</Layout>
