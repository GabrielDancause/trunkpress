---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "NewsMediaOrganization",
  "name": "Trunk Press",
  "url": "https://trunkpress.photonbuilder.com/",
  "description": "All the stories that matter."
};

// Load all articles from JSON
const articleFiles = import.meta.glob('../data/trunkpress/*.json', { eager: true });

interface Article {
  slug: string;
  title: string;
  description: string;
  category: string;
  published: string;
  tags?: string[];
  image?: string;
}

const articles: Article[] = Object.entries(articleFiles)
  .filter(([path]) => !path.includes('_schema') && !path.includes('_TEMPLATE'))
  .map(([_, mod]: [string, any]) => mod.default)
  .filter((a: any) => a?.slug)
  .sort((a: Article, b: Article) => (b.published || '').localeCompare(a.published || ''));

const categories = [
  { id: 'us', label: 'U.S. News', labelBadge: 'U.S. News', color: '#c8102e' },
  { id: 'world', label: 'World News', labelBadge: 'World', color: '#1a5c8a' },
  { id: 'politics', label: 'Politics', labelBadge: 'Politics', color: '#3a2060' },
  { id: 'business', label: 'Business & Economy', labelBadge: 'Business', color: '#1a5c30' },
  { id: 'health', label: 'Health', labelBadge: 'Health', color: '#8a2020' },
  { id: 'entertainment', label: 'Entertainment', labelBadge: 'Entertainment', color: '#8a6020' },
  { id: 'travel', label: 'Travel', labelBadge: 'Travel', color: '#1a4a6a' },
  { id: 'sports', label: 'Sports', labelBadge: 'Sports', color: '#1a3a5c' },
  { id: 'science', label: 'Science', labelBadge: 'Science', color: '#2a1e5e' },
  { id: 'climate', label: 'Climate & Environment', labelBadge: 'Climate', color: '#1a5c30' },
  { id: 'tech', label: 'Technology', labelBadge: 'Tech', color: '#8a4020' },
];

function truncate(text: string, max: number): string {
  if (!text || text.length <= max) return text || '';
  return text.slice(0, max).replace(/\s+\S*$/, '') + '…';
}

function articleImage(article: Article): string {
  // Use RSS source image if available, otherwise category fallback
  if ((article as any).image) return (article as any).image;
  return `/images/categories/${article.category || 'world'}.jpg`;
}

function timeAgo(dateStr: string): string {
  const d = new Date(dateStr + 'T12:00:00');
  const now = new Date();
  const diffH = Math.floor((now.getTime() - d.getTime()) / 3600000);
  if (diffH < 1) return 'Just now';
  if (diffH < 24) return `${diffH}h ago`;
  const diffD = Math.floor(diffH / 24);
  if (diffD === 1) return 'Yesterday';
  return `${diffD}d ago`;
}

// Trending tags from recent articles
const allTags = articles.slice(0, 30).flatMap(a => a.tags || []);
const tagCounts = allTags.reduce((acc, t) => { acc[t] = (acc[t] || 0) + 1; return acc; }, {} as Record<string, number>);
const trending = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]).slice(0, 8).map(([t]) => t);

// Hero: first article overall
const heroArticle = articles[0];
const heroSidebar = articles.slice(1, 5);
---

<Layout
  title="Trunk Press — All the Stories That Matter"
  description="Independent journalism. No filler, no spin — just the stories that matter."
  canonical="https://trunkpress.photonbuilder.com/"
  schema={schema}
>
  <!-- BREAKING TICKER -->
  {articles.length > 0 && (
    <div class="ticker-wrap">
      <div class="ticker-label">Breaking</div>
      <div class="ticker-track">
        <div class="ticker-items">
          {articles.slice(0, 6).map(a => (
            <a href={`/${a.slug}`}><span>{truncate(a.title, 70)}</span></a>
          ))}
          {articles.slice(0, 6).map(a => (
            <a href={`/${a.slug}`}><span>{truncate(a.title, 70)}</span></a>
          ))}
        </div>
      </div>
    </div>
  )}

  <div class="site-main">
    <!-- ═══ HERO ═══ -->
    {heroArticle && (
      <section class="hero-section reveal">
        <div class="hero-grid">
          <div class="hero-main">
            <a href={`/${heroArticle.slug}`} class="hero-img-link">
              <img src={articleImage(heroArticle)} alt={heroArticle.title} class="hero-img" loading="eager" />
            </a>
            <div class="hero-label"><span class="section-label">{categories.find(c => c.id === heroArticle.category)?.labelBadge || heroArticle.category}</span></div>
            <a href={`/${heroArticle.slug}`}>
              <h1>{heroArticle.title}</h1>
            </a>
            <p class="hero-deck">{truncate(heroArticle.description, 280)}</p>
            <div class="hero-meta">
              <span class="byline">Trunk Press</span>
              <span>{timeAgo(heroArticle.published)}</span>
            </div>
            <a href={`/${heroArticle.slug}`} class="read-more">Continue reading</a>
          </div>
          <div class="hero-sidebar">
            {heroSidebar.map(a => (
              <a href={`/${a.slug}`} class="sidebar-story has-thumb">
                <img src={articleImage(a)} alt="" class="sidebar-thumb" loading="lazy" />
                <div class="sidebar-text">
                  <span class="cat-tag">{categories.find(c => c.id === a.category)?.labelBadge || a.category}</span>
                  <h3>{truncate(a.title, 80)}</h3>
                  <div class="meta">{timeAgo(a.published)}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- TRENDING -->
    {trending.length > 0 && (
      <div class="trending-bar">
        <div class="trending-inner">
          <span class="trending-label">Trending</span>
          <div class="trending-items">
            {trending.map(tag => (
              <span class="trending-tag">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- ═══ CATEGORY SECTIONS ═══ -->
    {categories.map((cat, catIdx) => {
      const catArticles = articles.filter(a => a.category === cat.id);
      if (catArticles.length === 0) return null;

      const lead = catArticles[0];
      const rest = catArticles.slice(1, 4);
      const isLeadPlusTwo = rest.length >= 2;
      const isThreeCol = catArticles.length >= 3;

      return (
        <section class="reveal" id={cat.id}>
          <div class="section-header">
            <span class="section-label" style={`background:${cat.color}`}>{cat.labelBadge}</span>
            <h2><a href={`/category/${cat.id}`} style="color:inherit;text-decoration:none;">{cat.label}</a></h2>
            <a href={`/category/${cat.id}`} class="see-all">See all →</a>
          </div>

          {isLeadPlusTwo ? (
            <div class="lead-plus-two">
              <a href={`/${lead.slug}`} class="lead-story">
                <img src={articleImage(lead)} alt={lead.title} class="lead-img" loading="lazy" />
                <span class="cat-tag">{cat.labelBadge}</span>
                <h3>{lead.title}</h3>
                <p>{truncate(lead.description, 220)}</p>
                <div class="meta">Trunk Press · {timeAgo(lead.published)}</div>
                <span class="read-more">Read more</span>
              </a>
              <div class="two-stack">
                {rest.slice(0, 2).map(a => (
                  <a href={`/${a.slug}`} class="sidebar-story">
                    <span class="cat-tag">{cat.labelBadge}</span>
                    <h3>{truncate(a.title, 70)}</h3>
                    <div class="meta">{timeAgo(a.published)}</div>
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <div class="single-lead">
              <a href={`/${lead.slug}`} class="lead-story">
                <span class="cat-tag">{cat.labelBadge}</span>
                <h3>{lead.title}</h3>
                <p>{truncate(lead.description, 220)}</p>
                <div class="meta">Trunk Press · {timeAgo(lead.published)}</div>
              </a>
            </div>
          )}

          {catArticles.length > 3 && (
            <div class="three-col">
              {catArticles.slice(3, 6).map(a => (
                <a href={`/${a.slug}`} class="story-card">
                  <img src={articleImage(a)} alt="" class="card-img" loading="lazy" />
                  <span class="cat-tag">{cat.labelBadge}</span>
                  <h3>{truncate(a.title, 70)}</h3>
                  <p>{truncate(a.description, 120)}</p>
                  <div class="meta">{timeAgo(a.published)}</div>
                </a>
              ))}
            </div>
          )}
        </section>
      );
    })}

    {articles.length === 0 && (
      <div class="empty-state">
        <h2>Loading the presses…</h2>
        <p>Stories incoming. Check back soon.</p>
      </div>
    )}
  </div>
</Layout>

<style is:inline>
  /* ─── BREAKING NEWS TICKER ─── */
  .ticker-wrap {
    background: var(--accent);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    overflow: hidden;
    height: 32px;
    display: flex;
    align-items: center;
  }
  .ticker-label {
    background: #fff;
    color: var(--accent);
    padding: 0 14px;
    height: 100%;
    display: flex;
    align-items: center;
    white-space: nowrap;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    flex-shrink: 0;
    z-index: 1;
  }
  .ticker-track { overflow: hidden; flex: 1; }
  .ticker-items {
    display: flex;
    gap: 60px;
    animation: ticker 45s linear infinite;
    white-space: nowrap;
    padding-left: 30px;
  }
  .ticker-items a { color: #fff; text-decoration: none; }
  .ticker-items a:hover { color: #fff; }
  .ticker-items span::before { content: '◆ '; opacity: 0.6; }
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ─── MAIN LAYOUT ─── */
  .site-main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ─── SECTION HEADERS ─── */
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding: 32px 0 16px;
    border-bottom: 2px solid var(--ink);
    margin-bottom: 28px;
  }
  .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    flex: 1;
  }
  .see-all {
    font-size: 0.82rem;
    color: #888;
    text-decoration: none;
    white-space: nowrap;
  }
  .see-all:hover { color: var(--ink); }
  .section-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    background: var(--accent);
    padding: 3px 8px;
    border-radius: 2px;
    display: inline-block;
  }

  /* ─── CATEGORY TAG ─── */
  .cat-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* ─── HERO / LEAD STORY ─── */
  .hero-section { padding: 36px 0 0; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--col-gap);
    border-bottom: 1px solid var(--border);
    padding-bottom: 36px;
  }
  .hero-main {
    padding-right: var(--col-gap);
    border-right: 1px solid var(--border);
  }
  .hero-label { margin-bottom: 10px; }
  .hero-img {
    width: 100%;
    height: auto;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 16px;
    display: block;
  }
  .hero-img-link { display: block; text-decoration: none; }
  .hero-main h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3.5vw, 46px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
    color: var(--ink);
    transition: color 0.15s;
  }
  .hero-main a { text-decoration: none; }
  .hero-main a:hover h1 { color: var(--accent); }
  .hero-deck {
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-mid);
    font-weight: 300;
    margin-bottom: 16px;
    max-width: 600px;
  }
  .hero-meta {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: var(--ink-light);
    letter-spacing: 0.04em;
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 12px;
  }
  .hero-meta .byline { font-weight: 600; color: var(--ink-mid); }

  /* Sidebar stories */
  .hero-sidebar { display: flex; flex-direction: column; gap: 0; }
  .sidebar-story {
    display: block;
    padding: 16px 0;
    border-bottom: 1px solid var(--border-light);
    text-decoration: none;
    color: inherit;
  }
  .sidebar-story:first-child { padding-top: 0; }
  .sidebar-story:last-child { border-bottom: none; }
  .sidebar-story.has-thumb {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .sidebar-thumb {
    width: 100px;
    height: 68px;
    object-fit: cover;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .sidebar-text { flex: 1; min-width: 0; }
  .sidebar-story .cat { margin-bottom: 5px; }
  .sidebar-story h3 {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
    transition: color 0.15s;
  }
  .sidebar-story:hover h3 { color: var(--accent); }
  .sidebar-story p {
    font-size: 13.5px;
    color: var(--ink-mid);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sidebar-story .meta, .lead-story .meta, .story-card .meta {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    color: var(--ink-light);
    margin-top: 6px;
  }

  /* ─── TRENDING BAR ─── */
  .trending-bar {
    background: var(--paper-mid);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 16px 0;
    margin: 0 -24px 32px;
  }
  .trending-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .trending-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .trending-items { display: flex; gap: 8px; flex-wrap: wrap; }
  .trending-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-mid);
    background: #fff;
    border: 1px solid var(--border);
    padding: 4px 12px;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .trending-tag:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

  /* ─── LEAD + TWO LAYOUT ─── */
  .lead-plus-two {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--col-gap);
    padding-bottom: 36px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }
  .lead-story {
    display: block;
    padding-right: var(--col-gap);
    border-right: 1px solid var(--border-light);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }
  .lead-story:hover { opacity: 0.92; }
  .lead-img {
    width: 100%;
    height: auto;
    aspect-ratio: 16/9;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 14px;
    display: block;
  }
  .lead-story .cat-tag { margin-bottom: 8px; display: block; }
  .lead-story h3 {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin-bottom: 10px;
    transition: color 0.15s;
  }
  .lead-story:hover h3 { color: var(--accent); }
  .lead-story p {
    font-size: 15.5px;
    color: var(--ink-mid);
    line-height: 1.6;
    margin-bottom: 12px;
  }
  .two-stack { display: flex; flex-direction: column; gap: 0; }
  .two-stack .sidebar-story { flex: 1; }

  .single-lead {
    padding-bottom: 36px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }
  .single-lead .lead-story {
    border-right: none;
    padding-right: 0;
    max-width: 700px;
  }

  /* ─── THREE COLUMNS ─── */
  .three-col {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--col-gap);
    padding: 28px 0 36px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }
  .story-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }
  .story-card:hover { opacity: 0.92; }
  .card-img {
    width: 100%;
    height: auto;
    aspect-ratio: 16/10;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 12px;
    display: block;
  }
  .story-card .cat-tag { margin-bottom: 6px; display: block; }
  .story-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 19px;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
    transition: color 0.15s;
  }
  .story-card:hover h3 { color: var(--accent); }
  .story-card p {
    font-size: 14px;
    color: var(--ink-mid);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 10px;
  }
  /* col dividers */
  .three-col .story-card:not(:last-child) {
    padding-right: var(--col-gap);
    border-right: 1px solid var(--border-light);
  }

  /* ─── UTILITY ─── */
  .read-more {
    font-family: 'DM Sans', sans-serif;
    font-size: 11.5px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 8px;
    text-decoration: none;
  }
  .read-more::after { content: '→'; }
  .read-more:hover { color: var(--accent-dark); }

  .empty-state {
    text-align: center;
    padding: 6rem 1.5rem;
    font-family: 'Playfair Display', serif;
  }
  .empty-state h2 { font-size: 1.5rem; font-weight: 700; }
  .empty-state p { color: var(--ink-light); margin-top: 0.5rem; }

  /* ─── SCROLL REVEAL ─── */
  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-main { padding-right: 0; border-right: none; border-bottom: 1px solid var(--border); padding-bottom: 24px; }
    .three-col { grid-template-columns: 1fr 1fr; }
    .three-col .story-card:nth-child(3) { grid-column: span 2; border: none; padding-right: 0; }
    .lead-plus-two { grid-template-columns: 1fr; }
    .lead-story { border-right: none; padding-right: 0; border-bottom: 1px solid var(--border); padding-bottom: 20px; }
  }
  @media (max-width: 600px) {
    .three-col { grid-template-columns: 1fr; }
    .three-col .story-card { border-right: none !important; padding-right: 0 !important; }
    .three-col .story-card:nth-child(3) { grid-column: span 1; }
  }
</style>

<script>
  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  reveals.forEach(el => observer.observe(el));
</script>
